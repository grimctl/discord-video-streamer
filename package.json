{
  "name": "discord-video-streamer",
  "version": "0.1.0",
  "description": "Minimal Discord IPTV streamer focused on reliable $play URL streaming",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run build",
    "dev": "tsx src/index.ts",
    "healthcheck": "node build/healthcheck.js",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "dependencies": {
    "@dank074/discord-video-stream": "6.0.0",
    "discord.js-selfbot-v13": "3.7.1",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
